HOST=0.0.0.0
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/resto001

# `true` acepta cualquier origen. Para restringir, coloca `false`
# y usa CORS_ALLOWED_ORIGINS con una lista separada por comas.
CORS_ALLOW_ALL=true

# Ejemplo si quieres restringir manualmente:
# CORS_ALLOWED_ORIGINS=https://tu-backend.ngrok-free.app,https://tu-proyecto.expo.dev