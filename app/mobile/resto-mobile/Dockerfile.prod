FROM node:22-bookworm-slim AS build

WORKDIR /app/resto-mobile

COPY package.json /app/package.json
COPY app/mobile/resto-mobile/package*.json ./

RUN npm install

COPY app/mobile/resto-mobile ./

ENV EXPO_PUBLIC_API_URL=/api
ENV EXPO_PUBLIC_SOCKET_URL=/
ENV CI=1

RUN npx expo export --platform web

FROM nginx:1.27-alpine

COPY app/mobile/resto-mobile/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/resto-mobile/dist /usr/share/nginx/html

EXPOSE 80