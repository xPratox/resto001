# Red local por defecto.
EXPO_PUBLIC_API_URL_LOCAL=http://192.168.0.109:5000

# Activa el backend publico cuando trabajes con Expo tunnel.
EXPO_PUBLIC_USE_TUNNEL=false
EXPO_PUBLIC_API_URL_TUNNEL=https://tu-backend.ngrok-free.app

# Opcional: fuerza una URL exacta y tiene prioridad sobre todo lo demas.
# EXPO_PUBLIC_API_URL=https://tu-backend.ngrok-free.app

# Opcional: si Socket.IO usa otra URL publica distinta al REST.
# EXPO_PUBLIC_SOCKET_URL=https://tu-backend.ngrok-free.app

# Opcional: sobrescribe la deteccion automatica de Expo cuando necesites fijar el backend manualmente.
EXPO_PUBLIC_API_URL=http://TU_IP_LOCAL:5000