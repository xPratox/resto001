{
  "name": "resto001-workspace",
  "private": true,
  "scripts": {
    "start": "npm run dev",
    "dev:backend": "npm --prefix services/backend run dev",
    "dev:caja": "npm --prefix app/caja/web run dev",
    "dev:mobile": "npm --prefix app/mobile/resto-mobile run start",
    "dev": "npx concurrently -n backend,caja,mobile \"npm run dev:backend\" \"npm run dev:caja\" \"npm run dev:mobile\"",
    "dev:all": "npm run dev",
    "build:caja": "npm --prefix app/caja run build",
    "lint:mobile": "npm --prefix app/mobile/resto-mobile run lint",
    "verify:active": "npm run build:caja && npm run lint:mobile",
    "urls": "echo '\n==========================================\n 🚀 ENLACES RESTO 001 🚀\n==========================================\n 💰 Caja Web:      http://localhost:5175\n 📱 Expo Go:       http://localhost:19006\n==========================================\n'",
    "docker:up": "npm run docker:up:docker && npm run urls && echo '⏳ Levantando Expo en 5 segundos (abre los links antes de que Expo limpie la pantalla)...' && sleep 5 && npm --prefix app/mobile/resto-mobile run start -- --lan -c",
    "docker:up:docker": "docker compose -p resto001 --env-file .env.docker -f infra/docker/docker-compose.yml up --build -d",
    "docker:up:fg": "docker compose -p resto001 --env-file .env.docker -f infra/docker/docker-compose.yml up --build",
    "docker:down": "docker compose -p resto001 --env-file .env.docker -f infra/docker/docker-compose.yml down",
    "docker:ps": "docker compose -p resto001 --env-file .env.docker -f infra/docker/docker-compose.yml ps",
    "docker:logs": "docker compose -p resto001 --env-file .env.docker -f infra/docker/docker-compose.yml logs -f",
    "docker:prod:up": "docker compose -p resto001-prod --env-file .env.docker.prod -f infra/docker/docker-compose.prod.yml up --build",
    "docker:prod:down": "docker compose -p resto001-prod --env-file .env.docker.prod -f infra/docker/docker-compose.prod.yml down",
    "docker:smoke": "bash ./infra/scripts/docker-smoke-test.sh"
  },
  "dependencies": {
    "expo": "^55.0.17",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "concurrently": "^9.2.1",
    "typescript": "~5.9.2"
  }
}